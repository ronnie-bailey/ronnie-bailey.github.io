<script>
const archiveRepository = Array.from({length:24}, (_,i) => `images/gallery/gallery${String(i+1).padStart(2,'0')}.webp`);
const tileCount = 8;
const gallery = document.getElementById("rotatingGallery");

function visibleSources(){
  return Array.from(document.querySelectorAll('#rotatingGallery img')).map(img => img.getAttribute('src'));
}
function nextImage(current){
  const visible = new Set(visibleSources());
  const candidates = archiveRepository.filter(src => src !== current && !visible.has(src));
  const pool = candidates.length ? candidates : archiveRepository.filter(src => src !== current);
  return pool[Math.floor(Math.random() * pool.length)];
}

for(let i=0;i<tileCount;i++){
  const tile=document.createElement("div");
  tile.className="photo-tile";
  const img=document.createElement("img");
  img.src=archiveRepository[i % archiveRepository.length];
  img.alt="Archive preview";
  tile.appendChild(img);
  gallery.appendChild(tile);
}

setInterval(()=>{
  const tiles=document.querySelectorAll(".photo-tile");
  const tile=tiles[Math.floor(Math.random()*tiles.length)];
  const img=tile.querySelector("img");
  tile.classList.add("fade");
  setTimeout(()=>{
    img.src=nextImage(img.getAttribute('src'));
    tile.classList.remove("fade");
  },700);
},4200);
</script>

