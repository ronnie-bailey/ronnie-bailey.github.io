<style>
:root{
  --navy:#061a2b;
  --blue:#0b2a45;
  --blue2:#123a5e;
  --cream:#e9e4d4;
  --paper:#efe7d4;
  --muted:#c8d3dc;
  --gold:#c9a44a;
  --gold2:#e3c06a;
  --line:rgba(122,168,205,.22);
  --ink:#0b2238;
  --ink2:#17324d;
}

*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}

body{
  font-family:'Spectral', Georgia, serif;
  background:
    radial-gradient(circle at 75% 10%,rgba(227,192,106,.07),transparent 28%),
    linear-gradient(160deg,var(--navy),var(--blue) 48%,var(--blue2));
  color:var(--cream);
  line-height:1.65;
  min-height:100vh;
  overflow-x:hidden;
}

h1,h2,h3{font-family:'Cinzel',serif;font-weight:500}

/* ambient compass watermark, carried through the whole page rather than boxed to a header */
.background-atlas{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
.compass{position:absolute;width:1200px;height:1200px;top:-540px;left:-540px;opacity:.06;animation:compassRotate 420s linear infinite}
@keyframes compassRotate{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@media (prefers-reduced-motion: reduce){.compass{animation:none}.photo-tile img{transition:none}}

.shell{position:relative;z-index:2;max-width:1120px;margin:0 auto;padding:0 clamp(22px,4vw,54px)}

/* ---------- HERO: full-bleed photo, borrowed treatment, folded into the unified body ---------- */
header.hero{
  position:relative;
  min-height:640px;
  margin:0 calc(-1 * clamp(22px,4vw,54px));
  padding:0 clamp(22px,4vw,54px);
  display:flex;
  align-items:center;
  overflow:hidden;
}

header.hero::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(100deg,
      rgba(6,26,43,.98) 0%,
      rgba(6,26,43,.92) 22%,
      rgba(6,26,43,.68) 42%,
      rgba(6,26,43,.30) 64%,
      rgba(6,26,43,.06) 86%),
    url("images/capitol-rotunda.webp");
  background-size:cover;
  background-position:center top;
  filter:grayscale(.15) contrast(1.05);
  z-index:0;
}

.hero-inner{position:relative;z-index:1;max-width:640px;padding:96px 0 84px}

h1{
  font-size:clamp(2.6rem,6.4vw,4.5rem);
  letter-spacing:.07em;
  text-transform:uppercase;
  line-height:1.05;
}

.hero-sub{margin-top:22px;max-width:520px;color:var(--muted);font-size:1.1rem;font-weight:300}
.french-line{margin-top:14px;max-width:520px;color:var(--gold2);font-size:1rem;font-style:italic}

.hero-links{margin-top:28px;display:flex;flex-wrap:wrap;gap:10px}
.hero-links a{
  color:var(--cream);text-decoration:none;border:1px solid rgba(245,239,227,.28);
  padding:9px 15px;font-size:.9rem;background:rgba(6,26,43,.4);backdrop-filter:blur(2px);
}
.hero-links a:hover{color:var(--gold2);border-color:rgba(227,192,106,.6)}

/* ---------- Professional callout ---------- */
section{padding:34px 0}

.professional-callout{
  margin:0 auto;max-width:900px;border:1px solid rgba(201,164,74,.5);
  padding:20px 34px;text-align:center;color:var(--muted);
  background:rgba(255,255,255,.025);font-size:1.02rem;line-height:1.65;font-weight:300;
}
.professional-callout p{margin:0 auto;max-width:760px}
.professional-callout strong{color:var(--cream);font-weight:600}
.professional-callout a,.footer-identity-link{
  color:var(--gold2);text-decoration:none;border-bottom:1px solid rgba(227,192,106,.45);font-weight:600;
}
.professional-callout a:hover,.footer-identity-link:hover{color:var(--cream);border-color:var(--cream)}

/* ---------- Intro panel ---------- */
.intro{
  position:relative;overflow:hidden;background:var(--paper);color:var(--ink);
  padding:clamp(42px,5vw,64px) clamp(30px,6vw,72px);box-shadow:0 18px 45px rgba(0,0,0,.18);
}
.intro p{max-width:860px;margin:0 auto 2rem;color:var(--ink2);font-size:1.14rem;line-height:1.8}
.intro p:last-child{margin-bottom:0}

/* ---------- Section heads ---------- */
.sec-head{margin-bottom:24px}
h2{font-size:clamp(1.5rem,3vw,2rem);letter-spacing:.07em;text-transform:uppercase}
.fr-title{display:block;margin-top:2px;color:var(--gold2);font-family:'Spectral',Georgia,serif;font-size:1.02rem;font-style:italic;letter-spacing:0;text-transform:none;font-weight:300}
.sec-note{margin-top:12px;max-width:820px;color:var(--muted);font-size:1.02rem;font-weight:300}

/* ---------- Timeline ---------- */
.timeline{border-top:1px solid var(--line)}
.entry{display:grid;grid-template-columns:250px 1fr;gap:34px;padding:32px 0;border-bottom:1px solid var(--line)}
.when{color:var(--cream);font-size:1rem;font-weight:500;line-height:1.45}
.where{display:block;margin-top:8px;color:var(--muted);font-size:.96rem;font-weight:300}
.entry h3{font-size:1.1rem;letter-spacing:.03em;margin-bottom:4px}
.role{color:var(--gold2);font-size:.96rem;letter-spacing:.02em;margin-bottom:10px}
.entry p{color:var(--muted);max-width:820px;font-weight:300;font-size:1.01rem}
.ref-links{margin-top:12px;display:flex;flex-wrap:wrap;gap:10px}
.ref-links a{color:var(--gold2);text-decoration:none;border-bottom:1px solid rgba(227,192,106,.45);font-size:.94rem}
.ref-links a:hover{color:var(--cream);border-color:var(--cream)}

/* ---------- Profile panels ---------- */
.profile-panel{display:grid;grid-template-columns:minmax(0,1fr) 40%;gap:34px;align-items:stretch}
.profile-copy{border-top:1px solid var(--line);border-bottom:1px solid var(--line);padding:6px 0}
.profile-row{padding:24px 0;border-bottom:1px solid var(--line)}
.profile-row:last-child{border-bottom:none}
.profile-row h3{color:var(--cream);font-size:1.02rem;letter-spacing:.04em;margin-bottom:8px}
.profile-row p,.profile-row li{color:var(--muted);font-size:1.02rem;font-weight:300;max-width:620px}
.profile-row ul{list-style:none;columns:2;column-gap:34px}
.profile-row li{break-inside:avoid;margin-bottom:8px}

.study-photo,.heritage-photo{
  min-height:520px;background-size:cover;background-position:center;
  border:1px solid var(--line);box-shadow:0 18px 45px rgba(0,0,0,.25);
  filter:grayscale(.22) brightness(.9) contrast(1.04);
}
.study-photo{background-image:linear-gradient(rgba(6,26,43,.5),rgba(6,26,43,.68)),url("images/literature-study.webp")}
.heritage-photo{background-image:linear-gradient(rgba(6,26,43,.46),rgba(6,26,43,.64)),url("images/american-heritage.webp")}

/* ---------- Library cards ---------- */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px}
.card{background:var(--cream);color:var(--ink);padding:26px;box-shadow:0 14px 34px rgba(0,0,0,.16)}
.card h3{font-size:.98rem;letter-spacing:.04em;color:var(--ink);margin-bottom:10px}
.card ul{list-style:none}
.card li{margin-bottom:8px}
.reading-link{color:var(--ink2);text-decoration:none;border-bottom:1px solid rgba(18,58,94,.28)}
.reading-link:hover{color:var(--gold);border-color:var(--gold)}

/* ---------- Rotating archive gallery (dedupe logic ported from theme one) ---------- */
.gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.photo-tile{aspect-ratio:1/1;overflow:hidden;background:#0a253d;border:1px solid var(--line)}
.photo-tile img{width:100%;height:100%;object-fit:cover;display:block;opacity:.94;transform:scale(1.02);transition:opacity .7s ease,transform .7s ease}
.photo-tile.fade img{opacity:0;transform:scale(1.08)}

/* ---------- Contact ---------- */
.contact-grid{display:flex;flex-wrap:wrap;gap:14px}
.contact-grid a{display:flex;align-items:center;gap:10px;color:var(--cream);text-decoration:none;border:1px solid var(--line);padding:12px 18px;background:rgba(255,255,255,.04);font-size:1rem}
.contact-grid a:hover{color:var(--gold2);border-color:rgba(227,192,106,.55)}

.closing-quote{padding:22px 0 34px;border-top:1px solid var(--line)}
.closing-quote .quote{margin-top:0;padding:0;max-width:860px;font-size:.96rem;opacity:.84;color:var(--muted)}
.closing-quote .quote em{display:block;margin-top:10px;color:var(--gold2);font-size:.96rem;font-style:italic}

footer{padding:54px 0 44px;display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;color:var(--muted);font-size:.9rem}
footer a{text-decoration:none}

@media(max-width:900px){
  .profile-panel{grid-template-columns:1fr}
  .profile-row ul{columns:1}
  .study-photo,.heritage-photo{min-height:340px}
}
@media(max-width:800px){
  header.hero{min-height:520px}
  .hero-inner{padding:72px 0 64px}
  .entry{grid-template-columns:1fr}
  .gallery{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>

